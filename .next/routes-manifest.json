{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/emprendimientos/[id]",
      "regex": "^/emprendimientos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/emprendimientos/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/panel/[id]",
      "regex": "^/panel/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/panel/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/usuarios/[id]",
      "regex": "^/usuarios/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/usuarios/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/api/chat",
      "regex": "^/api/chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/chat(?:/)?$"
    },
    {
      "page": "/api/password/request",
      "regex": "^/api/password/request(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/password/request(?:/)?$"
    },
    {
      "page": "/api/password/reset",
      "regex": "^/api/password/reset(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/password/reset(?:/)?$"
    },
    {
      "page": "/api/register",
      "regex": "^/api/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/register(?:/)?$"
    },
    {
      "page": "/emprendimientos",
      "regex": "^/emprendimientos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/emprendimientos(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/formacion",
      "regex": "^/formacion(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/formacion(?:/)?$"
    },
    {
      "page": "/formacion/open",
      "regex": "^/formacion/open(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/formacion/open(?:/)?$"
    },
    {
      "page": "/formacion/recurso",
      "regex": "^/formacion/recurso(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/formacion/recurso(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/panel",
      "regex": "^/panel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/panel(?:/)?$"
    },
    {
      "page": "/panel/nuevo",
      "regex": "^/panel/nuevo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/panel/nuevo(?:/)?$"
    },
    {
      "page": "/perfil",
      "regex": "^/perfil(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/perfil(?:/)?$"
    },
    {
      "page": "/registro",
      "regex": "^/registro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/registro(?:/)?$"
    },
    {
      "page": "/reset",
      "regex": "^/reset(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reset(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}