generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  name             String
  role             Role               @default(STUDENT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  userType         UserType           
  accounts         Account[]
  messages         Message[]
  profile          Profile?
  sessions         Session[]
  trainingProgress TrainingProgress[]
  ventures         Venture[]
}

model Profile {
  id             String       @id @default(cuid())
  userId         String       @unique
  fullName       String?
  bio            String?
  avatarKey      String?
  website        String?
  linkedin       String?
  github         String?
  documentNumber String?
  program        String?
  instagram      String?
  roleTitle      String?
  availability   Availability @default(NONE)
  interests      String[]     @default([])
  links          Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Venture {
  id            String          @id @default(cuid())
  ownerId       String
  title         String
  summary       String
  stage         VentureStage    @default(IDEA)
  tags          String[]
  instagram     String?
  facebook      String?
  razonSocial         String?
  actividadEconomica  String?    @db.Text
  impactoSocial       String?    @db.Text
  objetivos           String?    @db.Text
  category      Category?
  contactNumber String?
  logoKey       String?
  coverKey      String?
  featured      Boolean         @default(false)
  published     Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  attachments   Attachment[]
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  updates       VentureUpdate[]
}

model VentureUpdate {
  id        String   @id @default(cuid())
  ventureId String
  content   String
  createdAt DateTime @default(now())
  venture   Venture  @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  ventureId String
  name      String
  url       String
  blobKey   String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
  venture   Venture  @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model TrainingModule {
  id          String   @id @default(cuid())
  title       String
  category    String
  path        String
  description String?
  createdAt   DateTime @default(now())
}

model TrainingProgress {
  id           String   @id @default(cuid())
  userId       String
  resourcePath String
  progress     Float    @default(1)
  openedAt     DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourcePath])
}

model Message {
  id        String      @id @default(cuid())
  userId    String?
  role      MessageRole @default(USER)
  content   String
  threadId  String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  STUDENT
  ADMIN
}

enum VentureStage {
  IDEA
  PROTOTYPE
  MVP
  GROWTH
}

enum Availability {
  NONE
  LOOKING_PARTNERS
  MENTORING
  FREELANCE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum UserType {
  ESTUDIANTE
  EGRESADO
}

enum Category {
  TECNOLOGIA
  COMERCIO
  SERVICIOS
  ALIMENTOS
  MODA
  EDUCACION
}